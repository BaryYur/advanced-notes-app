generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserAuthType {
  email
  google
}

enum TaskListType {
  home
  today
  completed
  default
}

model User {
  id                         String       @id @default(uuid())
  firstName                  String
  lastName                   String
  authType                   UserAuthType
  email                      String
  password                   String?
  passwordResetCode          Float?
  passwordResetCodeExpiresAt DateTime?
  taskLists                  TaskList[]   @relation("UserToTaskList")

  @@map("user")
}

model TaskList {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  name         String
  tasks        Task[]   @relation("TaskListToTask")
  userId       String
  user         User     @relation("UserToTaskList", fields: [userId], references: [id], onDelete: Cascade)
  color        String   @default("")
  emoji        String?
  tasksCounter Float    @default(0)
  createdAt    DateTime @default(now())

  @@unique([name, userId])
  @@map("task_list")
}

model Task {
  id         String      @id @default(dbgenerated("gen_random_uuid()"))
  userId     String
  title      String
  taskListId String?
  completed  Boolean     @default(false)
  note       String      @default("")
  taskList   TaskList?   @relation("TaskListToTask", fields: [taskListId], references: [id], onDelete: Cascade)
  date       DateTime?
  createdAt  DateTime    @default(now())
  taskOrders TaskOrder[]

  @@map("task")
}

model TaskOrder {
  id       String @id @default(dbgenerated("gen_random_uuid()"))
  taskId   String
  userId   String
  context  String
  position Float
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, context])
  @@index([userId, context])
  @@map("task_order")
}
